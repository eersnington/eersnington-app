{
  "name": "eersnington",
  "version": "0.4.0",
  "private": false,
  "description": "OpenTUI version of my site eers.dev",
  "keywords": [
    "bun",
    "opentui",
    "portfolio",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eersnington/eersnington-app",
    "directory": "apps/tui"
  },
  "bin": {
    "eersnington": "./dist/cli.js",
    "sreenarayanan": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "cargo run --manifest-path Cargo.toml",
    "build": "bun run scripts/build-npm.ts",
    "assemble": "bun run scripts/assemble-npm.ts",
    "check-types": "tsc --noEmit && REQUIRE_DIST=1 bun run scripts/check-npm-package.ts",
    "prepublishOnly": "bun run build && bun run check-types"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "catalog:"
  },
  "optionalDependencies": {}
}
