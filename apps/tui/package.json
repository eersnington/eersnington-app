{
  "name": "eersnington",
  "version": "0.6.0",
  "private": false,
  "description": "TUI version of my site eers.dev in Rust",
  "keywords": [
    "bun",
    "personal",
    "portfolio",
    "ratatui",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eersnington/eersnington-app",
    "directory": "apps/tui"
  },
  "bin": {
    "eersnington": "./dist/cli.js",
    "sreenarayanan": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "cargo run --manifest-path Cargo.toml",
    "build": "bun run scripts/build-npm.ts",
    "assemble": "bun run scripts/assemble-npm.ts",
    "check-package-versions": "bun run scripts/check-package-versions.ts",
    "check-types": "bun run check-package-versions && tsc --noEmit && REQUIRE_DIST=1 bun run scripts/check-npm-package.ts",
    "prepublishOnly": "bun run build && bun run check-types"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "catalog:"
  },
  "optionalDependencies": {
    "@eersnington/tui-darwin-arm64": "0.6.0",
    "@eersnington/tui-darwin-x64": "0.6.0",
    "@eersnington/tui-linux-arm64-gnu": "0.6.0",
    "@eersnington/tui-linux-arm64-musl": "0.6.0",
    "@eersnington/tui-linux-x64-gnu": "0.6.0",
    "@eersnington/tui-linux-x64-musl": "0.6.0"
  }
}
