{
  "name": "eersnington-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:tui": "turbo -F tui dev",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@eersnington/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eersnington/config": "workspace:*",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
